COMPOSE_PROJECT_NAME=forgeflow

POSTGRES_DB=forgeflow_db
POSTGRES_USER=forgeflow
POSTGRES_PASSWORD=forgeflow_local_password

APP_NAME=ForgeFlow
APP_ENV=local
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Jakarta

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=forgeflow_db
DB_USERNAME=forgeflow
DB_PASSWORD=forgeflow_local_password

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

AI_PROVIDER=openrouter
AI_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_GEMINI_MODEL=
AI_WORKFLOW_PROMPT_MAX_CHARS=8000
AI_WORKFLOW_MAX_STEPS=20
AI_WORKFLOW_TIMEOUT=300
AI_FAILURE_LOG_LIMIT=100

VITE_APP_NAME=ForgeFlow
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
VITE_TIMEZONE=Asia/Jakarta
VITE_AUTH_TOKEN_KEY=flowforge.token
VITE_AUTH_USER_KEY=flowforge.user
VITE_AUTH_TENANT_KEY=flowforge.tenant
VITE_DEMO_LOGIN_EMAIL=admin@flowforge.test
VITE_DEMO_LOGIN_PASSWORD=password
VITE_DEFAULT_USER_NAME=ForgeFlow Admin
VITE_DEFAULT_USER_EMAIL=admin@flowforge.test
VITE_SSE_EVENTS_PATH=/runs/:runId/events
VITE_RUN_LOGS_PATH=/runs/:runId/logs
VITE_USERS_PATH=/users
