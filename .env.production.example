COMPOSE_PROJECT_NAME=forgeflow-prod

POSTGRES_DB=forgeflow_db
POSTGRES_USER=forgeflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

APP_NAME=ForgeFlow
APP_ENV=production
APP_KEY=base64:CHANGE_ME_GENERATE_WITH_ARTISAN_KEY_GENERATE
APP_DEBUG=false
APP_URL=https://flowforge.iandev.my.id
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=forgeflow_db
DB_USERNAME=forgeflow
DB_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=flowforge.iandev.my.id

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@flowforge.iandev.my.id
MAIL_FROM_NAME="${APP_NAME}"

GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY
AI_PROVIDER=gemini
AI_GEMINI_MODEL=gemini-2.5-flash
AI_WORKFLOW_PROMPT_MAX_CHARS=8000
AI_WORKFLOW_MAX_STEPS=20
AI_WORKFLOW_TIMEOUT=300
AI_FAILURE_LOG_LIMIT=100

VITE_APP_NAME=ForgeFlow
VITE_API_BASE_URL=https://flowforge.iandev.my.id/api/v1
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
VITE_TIMEZONE=Asia/Jakarta
VITE_AUTH_TOKEN_KEY=flowforge.token
VITE_AUTH_USER_KEY=flowforge.user
VITE_AUTH_TENANT_KEY=flowforge.tenant
VITE_DEMO_LOGIN_EMAIL=
VITE_DEMO_LOGIN_PASSWORD=
VITE_DEFAULT_USER_NAME=ForgeFlow Admin
VITE_DEFAULT_USER_EMAIL=admin@flowforge.iandev.my.id
VITE_SSE_EVENTS_PATH=/runs/:runId/events
VITE_RUN_LOGS_PATH=/runs/:runId/logs
VITE_USERS_PATH=/users
